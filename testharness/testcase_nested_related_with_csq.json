{
  "_comment": "Variant of testcase_nested_related_2level.json that adds an inner EXISTS condition matching the truncated production AST pattern: WHERE channelId=X AND EXISTS(channel_participants WHERE channelId=X AND userId=currentUser). The exact prod second condition is unknown (log truncates at 200 chars), but EXISTS on channel_participants is the highest-likelihood guess for a per-channel-member visibility filter.",

  "schema": {
    "channels": {
      "columns": {
        "id": {"type": "string"},
        "name": {"type": "string"}
      },
      "primaryKey": ["id"]
    },
    "channel_participants": {
      "columns": {
        "id": {"type": "string"},
        "channelId": {"type": "string"},
        "userId": {"type": "string"}
      },
      "primaryKey": ["id"]
    },
    "conversations": {
      "columns": {
        "conversationId": {"type": "string"},
        "channelId": {"type": "string"},
        "lastActivityAt": {"type": "number"}
      },
      "primaryKey": ["conversationId"]
    }
  },

  "initialData": {
    "channels": [
      {"id": "chA", "name": "Channel A"}
    ],
    "channel_participants": [
      {"id": "pA1", "channelId": "chA", "userId": "user-1"},
      {"id": "pA2", "channelId": "chA", "userId": "user-2"},
      {"id": "pA3", "channelId": "chA", "userId": "user-3"}
    ],
    "conversations": [
      {"conversationId": "c1", "channelId": "chA", "lastActivityAt": 100},
      {"conversationId": "c2", "channelId": "chA", "lastActivityAt": 200},
      {"conversationId": "c3", "channelId": "chA", "lastActivityAt": 300},
      {"conversationId": "c5", "channelId": "chA", "lastActivityAt": 500},
      {"conversationId": "c6", "channelId": "chA", "lastActivityAt": 600},
      {"conversationId": "c7", "channelId": "chA", "lastActivityAt": 700}
    ]
  },

  "ast": {
    "table": "conversations",
    "where": {
      "type": "and",
      "conditions": [
        {
          "type": "simple",
          "op": "=",
          "left": {"type": "column", "name": "channelId"},
          "right": {"type": "literal", "value": "chA"}
        },
        {
          "type": "correlatedSubquery",
          "op": "EXISTS",
          "related": {
            "system": "client",
            "correlation": {"parentField": ["channelId"], "childField": ["channelId"]},
            "subquery": {
              "table": "channel_participants",
              "alias": "membership_check",
              "where": {
                "type": "simple",
                "op": "=",
                "left": {"type": "column", "name": "userId"},
                "right": {"type": "literal", "value": "user-1"}
              }
            }
          }
        }
      ]
    },
    "orderBy": [["lastActivityAt", "desc"], ["conversationId", "asc"]],
    "limit": 2,
    "related": [
      {
        "system": "client",
        "correlation": {"parentField": ["channelId"], "childField": ["id"]},
        "subquery": {
          "table": "channels",
          "alias": "channel",
          "related": [
            {
              "system": "client",
              "correlation": {"parentField": ["id"], "childField": ["channelId"]},
              "subquery": {
                "table": "channel_participants",
                "alias": "participants"
              }
            }
          ]
        }
      }
    ]
  },

  "mutations": [
    {
      "type": "add",
      "table": "conversations",
      "row": {"conversationId": "c4", "channelId": "chA", "lastActivityAt": 400}
    }
  ]
}

{
  "_comment": "Advance-path probe for the exclusive-cursor boundary. Hydrate page is empty (cursor=300 is newest, exclusive). Then churn: (1) insert c-300b at createdAt=300 (TIE at the exclusive boundary — must NOT appear), (2) insert c-250 at 250 (below cursor — must NOT appear), (3) insert c-400 at 400 (strictly after — MUST appear). Correct final page = {c-400} only.",

  "schema": {
    "channels": {
      "columns": {
        "id": {"type": "string"},
        "visibility": {"type": "string"}
      },
      "primaryKey": ["id"]
    },
    "conversations": {
      "columns": {
        "conversationId": {"type": "string"},
        "channelId": {"type": "string"},
        "createdAt": {"type": "number"}
      },
      "primaryKey": ["conversationId"]
    }
  },

  "initialData": {
    "channels": [
      {"id": "ch1", "visibility": "PUBLIC"}
    ],
    "conversations": [
      {"conversationId": "c-100", "channelId": "ch1", "createdAt": 100},
      {"conversationId": "c-200", "channelId": "ch1", "createdAt": 200},
      {"conversationId": "c-300", "channelId": "ch1", "createdAt": 300}
    ]
  },

  "ast": {
    "table": "conversations",
    "where": {
      "type": "and",
      "conditions": [
        {
          "type": "simple",
          "op": "=",
          "left": {"type": "column", "name": "channelId"},
          "right": {"type": "literal", "value": "ch1"}
        },
        {
          "type": "correlatedSubquery",
          "op": "EXISTS",
          "scalar": true,
          "related": {
            "correlation": {
              "parentField": ["channelId"],
              "childField": ["id"]
            },
            "subquery": {
              "table": "channels",
              "alias": "channels",
              "where": {
                "type": "simple",
                "op": "=",
                "left": {"type": "column", "name": "visibility"},
                "right": {"type": "literal", "value": "PUBLIC"}
              }
            }
          }
        }
      ]
    },
    "start": {"row": {"createdAt": 300}, "exclusive": true},
    "orderBy": [["createdAt", "asc"]],
    "limit": 50
  },

  "mutations": [
    {"type": "add", "table": "conversations", "row": {"conversationId": "c-300b", "channelId": "ch1", "createdAt": 300}},
    {"type": "add", "table": "conversations", "row": {"conversationId": "c-250", "channelId": "ch1", "createdAt": 250}},
    {"type": "add", "table": "conversations", "row": {"conversationId": "c-400", "channelId": "ch1", "createdAt": 400}}
  ]
}
